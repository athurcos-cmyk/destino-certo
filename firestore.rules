rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Só usar a partir de subcoleções (dias/paradas), onde "resource" é o filho
    // e precisamos checar o roteiro pai — get() nesse caso é necessário.
    function roteiroPai(roteiroId) {
      return get(/databases/$(database)/documents/roteiros/$(roteiroId)).data;
    }

    function isOwnerDoPai(roteiroId) {
      return isSignedIn() && roteiroPai(roteiroId).donoId == request.auth.uid;
    }

    function isCollaboratorDoPai(roteiroId) {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email in roteiroPai(roteiroId).colaboradoresEmail;
    }

    function canEditPai(roteiroId) {
      return isOwnerDoPai(roteiroId) || isCollaboratorDoPai(roteiroId);
    }

    // Roteiros
    match /roteiros/{roteiroId} {
      // Dentro do próprio documento "resource" já é o roteiro — nunca usar
      // get() aqui (quebra list queries com permissão negada).
      function isOwner() {
        return isSignedIn() && resource.data.donoId == request.auth.uid;
      }

      function isCollaborator() {
        return isSignedIn()
          && request.auth.token.email != null
          && request.auth.token.email in resource.data.colaboradoresEmail;
      }

      // Owner and collaborators can read. Public sharing allows anyone to read.
      allow read: if isOwner()
        || isCollaborator()
        || resource.data.compartilhamentoAtivo == true;

      // Signed-in users can create (must set own UID as donoId)
      allow create: if isSignedIn()
        && request.resource.data.donoId == request.auth.uid;

      // Owner can update anything. Collaborators can update content fields only —
      // they cannot change ownership, the collaborator list, or sharing settings.
      allow update: if isOwner()
        || (
          isCollaborator()
          && request.resource.data.donoId == resource.data.donoId
          && request.resource.data.colaboradoresEmail == resource.data.colaboradoresEmail
          && request.resource.data.compartilhamentoAtivo == resource.data.compartilhamentoAtivo
          && request.resource.data.slugCompartilhamento == resource.data.slugCompartilhamento
        );

      allow delete: if isOwner();
    }

    // Dias - inherit from parent roteiro
    match /roteiros/{roteiroId}/dias/{diaId} {
      allow read: if isOwnerDoPai(roteiroId)
        || isCollaboratorDoPai(roteiroId)
        || roteiroPai(roteiroId).compartilhamentoAtivo == true;
      allow create, update, delete: if canEditPai(roteiroId);
    }

    // Paradas - inherit from parent roteiro via dia
    match /roteiros/{roteiroId}/dias/{diaId}/paradas/{paradaId} {
      allow read: if isOwnerDoPai(roteiroId)
        || isCollaboratorDoPai(roteiroId)
        || roteiroPai(roteiroId).compartilhamentoAtivo == true;
      allow create, update, delete: if canEditPai(roteiroId);
    }

    // Usuarios - users can read/write only their own
    match /usuarios/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }
  }
}
